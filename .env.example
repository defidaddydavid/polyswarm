# LLM Provider: "anthropic", "openai", or "ollama"
LLM_PROVIDER=anthropic

# API Keys (only need the one for your chosen provider)
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434

# Model overrides (optional — sensible defaults per provider)
# MODEL_FAST — used for agent estimates (fast, cheap)
# MODEL_DEEP — used for synthesis/aggregation narratives (optional, slower, smarter)
# MODEL_FAST=claude-sonnet-4-20250514
# MODEL_DEEP=claude-sonnet-4-20250514
# MODEL_FAST=gpt-4o-mini
# MODEL_FAST=llama3.1:8b

# ═══════════════════════════════════════════
# Data Source API Keys (all optional — sources work without keys but may be rate-limited)
# ═══════════════════════════════════════════

# Etherscan — ETH gas prices (works without key, rate-limited)
# ETHERSCAN_API_KEY=your_key_here

# CryptoPanic — news headlines (works with free token)
# CRYPTOPANIC_API_KEY=your_key_here

# CoinGecko Pro — higher rate limits (free tier works fine)
# COINGECKO_API_KEY=your_key_here

# Glassnode — on-chain analytics (requires paid plan)
# GLASSNODE_API_KEY=your_key_here

# Santiment — social/on-chain data (requires paid plan)
# SANTIMENT_API_KEY=your_key_here

# CoinMetrics — institutional-grade market data
# COINMETRICS_API_KEY=your_key_here

# ═══════════════════════════════════════════
# Data Source Configuration
# ═══════════════════════════════════════════

# Whitelist specific sources (comma-separated, default: all available)
# POLYSWARM_SOURCES=binance_spot,funding_rates,fear_greed,btc_options

# Prediction Markets
POLYMARKET_API_URL=https://clob.polymarket.com
MANIFOLD_API_URL=https://api.manifold.markets/v0

# ═══════════════════════════════════════════
# Infrastructure
# ═══════════════════════════════════════════
REDIS_URL=redis://localhost:6379
DATABASE_URL=sqlite+aiosqlite:///./polyswarm.db

# Swarm Config
DEBATE_ROUNDS=2
SWARM_SIZE=12

# API Authentication (optional — if set, requires X-API-Key header)
# POLYSWARM_API_KEY=your_secret_key_here
